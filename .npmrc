# ── Auth ──────────────────────────────────────────────────────────
# Usa NPM_TOKEN env var per autenticarsi su registry.npmjs.org
# Necessario per npm publish in locale e CI/CD
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# ── Publish ───────────────────────────────────────────────────────
# Accesso pubblico di default (overrideabile per-package)
access=public

# ── Pnpm ──────────────────────────────────────────────────────────
# Usa pnpm per gestire il monorepo
package-manager=pnpm@latest

# Non aggiornare il lockfile in fase di installazione
lockfile=false

# Usa il node_modules standard (non hoisted) per compatibilità
node-linker=hoisted

# Salva i workspace protocol in dependencies
save-workspace-protocol=true
